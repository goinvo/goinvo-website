# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3000/studio

# Sanity API Token (Viewer permissions - used for draft mode and visual editing)
SANITY_API_READ_TOKEN=your_viewer_token

# Sanity API Token (Editor permissions - used by website chat and draft helpers)
SANITY_WRITE_TOKEN=your_editor_token

# GoInvo website chat
CHAT_WIDGET_ENABLED=true
CHAT_WIDGET_ALLOWED_HOSTS=goinvo.com,www.goinvo.com,localhost,127.0.0.1
CHAT_IP_HASH_SALT=replace_with_random_salt
NEXT_PUBLIC_SITE_URL=https://www.goinvo.com
CHAT_STUDIO_BASE_URL=https://your-next-site.example.com

# Backup email for unanswered website chat threads
RESEND_API_KEY=re_your_resend_api_key
CHAT_NO_RESPONSE_EMAIL_ENABLED=true
CHAT_NO_RESPONSE_EMAIL_FROM="GoInvo <hello@goinvo.com>"
CHAT_NO_RESPONSE_EMAIL_REPLY_TO=hello@goinvo.com

# Slack app for website chat
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHAT_CHANNEL_ID=C0B5EC9LGFJ
CHAT_SLACK_DEDICATED_CHANNELS=true
CHAT_SLACK_CHANNEL_PING=<!here>

# Optional one-time Slack OAuth setup callback. Keep disabled in production.
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_OAUTH_SETUP_ENABLED=false
SLACK_OAUTH_SETUP_STATE=replace_with_random_state
