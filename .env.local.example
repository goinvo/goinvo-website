# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3000/studio

# Sanity API Token (Viewer permissions - used for draft mode and visual editing)
SANITY_API_READ_TOKEN=your_viewer_token

# Sanity API Token (Editor permissions - used to write CMS records, including the
# A/B test performance signals the analytics drain upserts). Either name works.
SANITY_WRITE_TOKEN=your_editor_token

# Google Search Console verification. Paste the content="" value from the GSC
# "HTML tag" verification method. Emits <meta name="google-site-verification">
# on every page; set it in Vercel (Production), redeploy, then click Verify.
GOOGLE_SITE_VERIFICATION=your_gsc_html_tag_token

# Vercel Flags (used for page experiments and Flags Explorer)
FLAGS=your_vercel_flags_sdk_key
FLAGS_SECRET=your_32_byte_base64url_secret

# Optional access gate for the shareable marketing-plan deck (/marketing-plan).
# The page is always noindex and is absent from the sitemap/nav. If this is SET,
# the page additionally requires a matching ?k=<key> query param, otherwise it
# returns 404 (notFound). If LEFT UNSET, the page is simply unlisted (no gate) —
# reachable by anyone who knows the URL. Use a long random string when sharing
# externally, e.g. /marketing-plan?k=your_long_random_key
# MARKETING_PLAN_KEY=your_long_random_key

# ── Marketing CMS assistant (AI) ─────────────────────────────────────────────
# Powers the marketing tool's AI: Strategist Chat plus every "assist" action
# (campaign, research project/plan, content draft, strategy assets, experiments).
# Without any AI key the assistant still responds, but only with rule-based
# stubs — the /api/marketing/assist response reports usedAi:false. Set at least
# OPENAI_API_KEY and the whole assistant turns on, locally and in production.
#
# OpenAI key — drives every structured assist action via the Responses API
# (default model gpt-4o-mini) and is the strategist's fallback.
OPENAI_API_KEY=your_openai_api_key
# Vercel AI Gateway key — lets Strategist Chat use the gateway model
# (default openai/gpt-5.4). On Vercel the gateway is auto-authorized via OIDC,
# so this is only needed to exercise the strategist locally. Optional.
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
# Optional model / timeout overrides:
# MARKETING_AI_MODEL=gpt-4o-mini
# MARKETING_STRATEGIST_AI_MODEL=openai/gpt-5.4
# MARKETING_AI_TIMEOUT_MS=30000

# ── Marketing research (SEO provider scores) ─────────────────────────────────
# Semrush API key — the Research view sends seed keywords to Semrush for real
# search volume / difficulty (api/marketing/research/run). Without it, research
# returns AI seed ideas only and warns that no provider SEO scores were created.
# (There is no Google Search Console API integration; "gsc" is only a manual
# provider label for performance signals you record by hand.)
SEMRUSH_API_KEY=your_semrush_api_key

# TextFocus REST API key, textfocus.net — powers the SEO suite's TextFocus
# scoring (tf_seo / tf_geo / tf_semantic / tf_keyword / tf_robotstxt). Sent as a
# form field named `key` (not a header). The free tf_account health-check gates
# every paid call, so without this the suite degrades gracefully (no scores).
TEXTFOCUS_API_KEY=

# Vercel Web Analytics drain (POST /api/marketing/analytics/vercel-drain).
# Shared secret used to authorize incoming drain requests. Configure the same
# value as a Bearer token / signing secret on the Vercel drain. Without it the
# endpoint returns 500 and never writes to Sanity.
MARKETING_VERCEL_DRAIN_SECRET=your_long_random_drain_secret
# Origin used to build the experiment page URL stored on the readout signal.
MARKETING_SITE_ORIGIN=https://www.goinvo.com

# First-party A/B collection (closes the measurement loop).
# The site beacons experiment events to /api/marketing/analytics/collect, which
# increments per-variant counters in Vercel KV (counts only, no visitor IDs).
# A daily Vercel Cron (vercel.json -> /api/marketing/analytics/drain-cron) rolls
# those counters into the readout signal. Provision Vercel KV (or Upstash Redis)
# and these are set for you; without them, collection no-ops gracefully.
KV_REST_API_URL=your_vercel_kv_rest_url
KV_REST_API_TOKEN=your_vercel_kv_rest_token
# Authorizes the Vercel Cron rollup. Vercel sends it as `Authorization: Bearer`.
# Falls back to MARKETING_VERCEL_DRAIN_SECRET if unset.
CRON_SECRET=your_long_random_cron_secret

# GA4 Measurement Protocol forward (recovers blocked experiment events for GA4).
# /api/marketing/analytics/collect already receives ~100% of experiment events
# first-party; GA4's client gtag only delivers ~5% (ad/tracking blockers). When
# this secret is set, /collect re-sends each EVENT (not the engagement beacon) to
# GA4 via the Measurement Protocol, keyed off the visitor's own _ga client_id.
# To avoid double-counting, the client gtag is SKIPPED for experiment events, so
# MP is their single path to GA4; general (non-experiment) analytics still use
# gtag. The feature is INERT until GA4_MP_API_SECRET is set (forwards nothing).
# Create the secret in GA4 Admin → Data streams → (web stream) → Measurement
# Protocol API secrets. GA4_MEASUREMENT_ID is optional (defaults to the site's
# G-P00K4KL2Y9 web stream).
GA4_MP_API_SECRET=your_ga4_measurement_protocol_api_secret
# GA4_MEASUREMENT_ID=G-P00K4KL2Y9

# Marketing SEO opportunities (Search Console + GA4) - api/marketing/seo
# Full service-account JSON on one line; the SA needs Search Console access
# (verified owner) on the property and GA4 Viewer. Without it the dashboard
# SEO view reports configured:false instead of showing live data.
GOOGLE_SERVICE_ACCOUNT_JSON=your_service_account_json_one_line
# GOINVO_GSC_SITE_URL=https://www.goinvo.com/
# GOINVO_GA4_PROPERTY_ID=321528631
