{
  "display_information": {
    "name": "GoInvo Website Chat",
    "description": "Routes goinvo.com website chat threads into Slack and back into Sanity.",
    "background_color": "#B84A0E"
  },
  "features": {
    "bot_user": {
      "display_name": "GoInvo Website Chat",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "http://localhost:3000/api/slack/oauth",
      "https://www.goinvo.com/api/slack/oauth"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "channels:write",
        "files:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://www.goinvo.com/api/slack/events",
      "bot_events": [
        "message.channels"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://www.goinvo.com/api/slack/interactions"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
